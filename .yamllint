---
# yamllint (https://yamllint.readthedocs.io/) — relaxed defaults that
# fit real-world GitHub Actions and issue-template YAML.
extends: default

rules:
  # Workflow / issue-template YAML routinely runs past 80 columns (URLs,
  # descriptions, ${{ ... }} expressions). 120 is the practical ceiling;
  # keep it a warning so length never blocks a commit.
  line-length:
    max: 120
    level: warning
  # `on:` in a workflow is the canonical Actions trigger key, not a bool.
  truthy:
    check-keys: false
  # `---` document-start is noise for single-document config files.
  document-start: disable
  # This repo is Windows-primary and checks out CRLF (.editorconfig end_of_line=crlf,
  # .gitattributes text=auto). Don't enforce unix newlines on YAML — it fails only on
  # the Windows CI checkout, not locally. Line-ending policy is owned by gitattributes.
  new-lines: disable
