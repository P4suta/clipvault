<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ClipVaultApp.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="using:ClipVaultApp.Localization"
    xmlns:local="using:ClipVaultApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="using:ClipVaultApp.ViewModels"
    Title="ClipVault"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="ClipVault"
            Grid.Row="0">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="Nav"
            Grid.Row="1"
            AutomationProperties.AutomationId="SettingsNav"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    AutomationProperties.AutomationId="NavSettings"
                    Content="{loc:Str Key=Settings.Nav.Settings}"
                    IsSelected="True"
                    Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.AutomationId="NavPrivacy"
                    Content="{loc:Str Key=Settings.Nav.Privacy}"
                    Tag="privacy">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <!--  ===== Settings pane =====  -->
                <ScrollViewer x:Name="SettingsPane" Padding="{StaticResource PagePadding}">
                    <StackPanel
                        MaxWidth="{StaticResource SettingsContentMaxWidth}"
                        Spacing="{StaticResource SpacingSmall}">

                        <!--  Language  -->
                        <controls:SettingsCard
                            Description="{loc:Str Key=Settings.Language.Hint}"
                            Header="{loc:Str Key=Settings.Language.Label}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE774;}">
                            <ComboBox
                                MinWidth="{StaticResource InputMinWidth}"
                                AutomationProperties.AutomationId="LanguageSelector"
                                AutomationProperties.Name="{loc:Str Key=Settings.Language.Label}"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneTime}"
                                SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <!--  App theme  -->
                        <controls:SettingsCard
                            Description="{loc:Str Key=Settings.Theme.Hint}"
                            Header="{loc:Str Key=Settings.Theme.Label}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE771;}">
                            <ComboBox
                                MinWidth="{StaticResource InputMinWidth}"
                                AutomationProperties.AutomationId="ThemeSelector"
                                AutomationProperties.Name="{loc:Str Key=Settings.Theme.Label}"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneTime}"
                                SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <!--  Storage mode  -->
                        <controls:SettingsCard
                            ContentAlignment="Vertical"
                            Description="{loc:Str Key=Settings.Storage.Hint}"
                            Header="{loc:Str Key=Settings.Storage.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}">
                            <RadioButtons AutomationProperties.AutomationId="StorageModeGroup">
                                <RadioButton
                                    AutomationProperties.AutomationId="StorageEncryptedRadio"
                                    Content="{loc:Str Key=Settings.Storage.Encrypted}"
                                    IsChecked="{x:Bind ViewModel.IsEncryptedDisk, Mode=TwoWay}" />
                                <RadioButton
                                    AutomationProperties.AutomationId="StorageVolatileRadio"
                                    Content="{loc:Str Key=Settings.Storage.Volatile}"
                                    IsChecked="{x:Bind ViewModel.IsVolatileMemory, Mode=TwoWay}" />
                            </RadioButtons>
                        </controls:SettingsCard>

                        <!--  Key protection (passphrase / Windows Hello, mutually exclusive)  -->
                        <controls:SettingsCard
                            ContentAlignment="Vertical"
                            Description="{loc:Str Key=Settings.Protection.Hint}"
                            Header="{loc:Str Key=Settings.Protection.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE72E;}"
                            Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsPassphraseSectionVisible), Mode=OneWay}">
                            <StackPanel Spacing="{StaticResource SpacingMedium}">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{loc:Str Key=Settings.Protection.Current}" />
                                    <TextBlock
                                        AutomationProperties.AutomationId="ProtectionDisplay"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind ViewModel.ProtectionDisplay, Mode=OneWay}" />
                                </StackPanel>

                                <!--  Shared feedback (passphrase / Hello operation results)  -->
                                <InfoBar
                                    AutomationProperties.AutomationId="PassphraseErrorBar"
                                    IsClosable="False"
                                    IsOpen="{x:Bind ViewModel.HasPassphraseError, Mode=OneWay}"
                                    Message="{x:Bind ViewModel.PassphraseError, Mode=OneWay}"
                                    Severity="Error" />
                                <InfoBar
                                    AutomationProperties.AutomationId="PassphraseSuccessBar"
                                    IsClosable="False"
                                    IsOpen="{x:Bind ViewModel.HasPassphraseSuccess, Mode=OneWay}"
                                    Message="{x:Bind ViewModel.PassphraseSuccess, Mode=OneWay}"
                                    Severity="Success" />

                                <!--  Current passphrase (only while passphrase-protected: change / remove / switch to Hello)  -->
                                <PasswordBox
                                    x:Name="CurrentPassphraseBox"
                                    AutomationProperties.AutomationId="CurrentPassphraseBox"
                                    AutomationProperties.Name="{loc:Str Key=Settings.Passphrase.CurrentHeader}"
                                    Header="{loc:Str Key=Settings.Passphrase.CurrentHeader}"
                                    PasswordChanged="OnCurrentPassphraseChanged"
                                    PlaceholderText="{loc:Str Key=Settings.Passphrase.CurrentPlaceholder}"
                                    Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.HasPassphrase), Mode=OneWay}" />

                                <!--  Set / change / remove passphrase (DPAPI-only or passphrase mode; hidden under Hello)  -->
                                <StackPanel
                                    Spacing="{StaticResource SpacingMedium}"
                                    Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsPassphraseControlsVisible), Mode=OneWay}">
                                    <PasswordBox
                                        x:Name="NewPassphraseBox"
                                        AutomationProperties.AutomationId="NewPassphraseBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Passphrase.NewHeader}"
                                        Header="{loc:Str Key=Settings.Passphrase.NewHeader}"
                                        PasswordChanged="OnNewPassphraseChanged"
                                        PlaceholderText="{loc:Str Key=Settings.Passphrase.NewPlaceholder}" />

                                    <PasswordBox
                                        x:Name="ConfirmPassphraseBox"
                                        AutomationProperties.AutomationId="ConfirmPassphraseBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Passphrase.ConfirmHeader}"
                                        Header="{loc:Str Key=Settings.Passphrase.ConfirmHeader}"
                                        PasswordChanged="OnConfirmPassphraseChanged"
                                        PlaceholderText="{loc:Str Key=Settings.Passphrase.ConfirmPlaceholder}" />

                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                        <Button
                                            AutomationProperties.AutomationId="SavePassphraseButton"
                                            Command="{x:Bind ViewModel.SavePassphraseCommand}"
                                            Content="{loc:Str Key=Settings.Passphrase.Save}"
                                            IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                            Style="{StaticResource AccentButtonStyle}" />
                                        <Button
                                            AutomationProperties.AutomationId="RemovePassphraseButton"
                                            Command="{x:Bind ViewModel.RemovePassphraseCommand}"
                                            Content="{loc:Str Key=Settings.Passphrase.Remove}"
                                            IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                            Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.HasPassphrase), Mode=OneWay}" />
                                        <ProgressRing
                                            Width="{StaticResource ProgressRingSize}"
                                            Height="{StaticResource ProgressRingSize}"
                                            VerticalAlignment="Center"
                                            IsActive="{x:Bind ViewModel.IsPassphraseBusy, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Windows Hello  -->
                                <Border
                                    Padding="{StaticResource SubsectionDividerPadding}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="{StaticResource SubsectionDividerThickness}">
                                    <StackPanel Spacing="{StaticResource SpacingMedium}">
                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontSize="{StaticResource IconSizeMedium}"
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                Glyph="&#xE8FB;" />
                                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Windows Hello" />
                                        </StackPanel>
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{loc:Str Key=Settings.Hello.Hint}"
                                            TextWrapping="Wrap" />

                                        <!--  Unavailable hint (when Hello cannot be used on this PC)  -->
                                        <InfoBar
                                            AutomationProperties.AutomationId="HelloUnavailableBar"
                                            IsClosable="False"
                                            IsOpen="{x:Bind ViewModel.IsHelloUnavailableHintVisible, Mode=OneWay}"
                                            Message="{loc:Str Key=Settings.Hello.Unavailable}"
                                            Severity="Informational" />

                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                            <Button
                                                AutomationProperties.AutomationId="EnableHelloButton"
                                                Command="{x:Bind ViewModel.EnableHelloCommand}"
                                                Content="{loc:Str Key=Settings.Hello.Enable}"
                                                IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsHelloEnableVisible), Mode=OneWay}" />
                                            <Button
                                                AutomationProperties.AutomationId="DisableHelloButton"
                                                Command="{x:Bind ViewModel.DisableHelloCommand}"
                                                Content="{loc:Str Key=Settings.Hello.Disable}"
                                                IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                                Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsHelloProtected), Mode=OneWay}" />
                                            <ProgressRing
                                                Width="20"
                                                Height="20"
                                                VerticalAlignment="Center"
                                                IsActive="{x:Bind ViewModel.IsPassphraseBusy, Mode=OneWay}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </controls:SettingsCard>

                        <!--  Excluded apps  -->
                        <controls:SettingsCard
                            ContentAlignment="Vertical"
                            Description="{loc:Str Key=Settings.Excluded.Hint}"
                            Header="{loc:Str Key=Settings.Excluded.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE71D;}">
                            <StackPanel Spacing="{StaticResource SpacingMedium}">
                                <Grid ColumnSpacing="{StaticResource SpacingSmall}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewExcludedAppBox"
                                        Grid.Column="0"
                                        AutomationProperties.AutomationId="NewExcludedAppBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Excluded.InputName}"
                                        KeyDown="OnNewExcludedAppKeyDown"
                                        PlaceholderText="{loc:Str Key=Settings.Excluded.Placeholder}"
                                        Text="{x:Bind ViewModel.NewExcludedApp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="AddExcludedAppButton"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Excluded.Add}"
                                        Command="{x:Bind ViewModel.AddExcludedAppCommand}"
                                        Content="{loc:Str Key=Settings.Excluded.Add}" />
                                </Grid>
                                <ItemsControl
                                    AutomationProperties.AutomationId="ExcludedAppsList"
                                    ItemsSource="{x:Bind ViewModel.ExcludedApps, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ExcludedAppViewModel">
                                            <Grid Padding="{StaticResource ExclusionRowPadding}" ColumnSpacing="{StaticResource SpacingSmall}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind Name}" />
                                                <Button
                                                    Grid.Column="1"
                                                    AutomationProperties.AutomationId="RemoveExcludedAppButton"
                                                    AutomationProperties.Name="{loc:Str Key=Settings.Excluded.RemoveName}"
                                                    Command="{x:Bind local:SettingsWindow.RemoveExcludedAppCommand}"
                                                    CommandParameter="{x:Bind}"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    ToolTipService.ToolTip="{loc:Str Key=Settings.Excluded.RemoveTooltip}">
                                                    <FontIcon FontSize="{StaticResource IconSizeSmall}" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </controls:SettingsCard>

                        <!--  Mask generic passwords  -->
                        <controls:SettingsCard
                            Description="{loc:Str Key=Settings.Mask.Hint}"
                            Header="{loc:Str Key=Settings.Mask.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xED1A;}">
                            <ToggleSwitch
                                AutomationProperties.AutomationId="MaskPasswordsToggle"
                                AutomationProperties.Name="{loc:Str Key=Settings.Mask.Header}"
                                IsOn="{x:Bind ViewModel.MaskGenericPasswords, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <!--  Strip URL tracking parameters  -->
                        <controls:SettingsCard
                            Description="{loc:Str Key=Settings.StripTracking.Hint}"
                            Header="{loc:Str Key=Settings.StripTracking.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE71B;}">
                            <ToggleSwitch
                                AutomationProperties.AutomationId="StripTrackingToggle"
                                AutomationProperties.Name="{loc:Str Key=Settings.StripTracking.Header}"
                                IsOn="{x:Bind ViewModel.StripTrackingParameters, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <!--  Retention  -->
                        <controls:SettingsExpander
                            Description="{loc:Str Key=Settings.Retention.Hint}"
                            Header="{loc:Str Key=Settings.Retention.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE787;}">
                            <controls:SettingsExpander.Items>
                                <controls:SettingsCard Header="{loc:Str Key=Settings.Retention.MaxDays}">
                                    <NumberBox
                                        MinWidth="{StaticResource InputMinWidth}"
                                        AutomationProperties.AutomationId="MaxAgeDaysBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Retention.MaxDays}"
                                        Maximum="3650"
                                        Minimum="1"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Inline"
                                        Value="{x:Bind ViewModel.MaxAgeDaysValue, Mode=TwoWay}" />
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="{loc:Str Key=Settings.Retention.MaxEntries}">
                                    <NumberBox
                                        MinWidth="{StaticResource InputMinWidth}"
                                        AutomationProperties.AutomationId="MaxEntriesBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Retention.MaxEntries}"
                                        Maximum="1000000"
                                        Minimum="1"
                                        SmallChange="10"
                                        SpinButtonPlacementMode="Inline"
                                        Value="{x:Bind ViewModel.MaxEntriesValue, Mode=TwoWay}" />
                                </controls:SettingsCard>
                            </controls:SettingsExpander.Items>
                        </controls:SettingsExpander>

                        <!--  Auto start  -->
                        <controls:SettingsCard
                            Description="{loc:Str Key=Settings.AutoStart.Hint}"
                            Header="{loc:Str Key=Settings.AutoStart.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE7E8;}">
                            <ToggleSwitch
                                AutomationProperties.AutomationId="RunAtStartupToggle"
                                AutomationProperties.Name="{loc:Str Key=Settings.AutoStart.Header}"
                                IsOn="{x:Bind ViewModel.RunAtStartup, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <!--  Panic wipe (destructive)  -->
                        <controls:SettingsCard
                            Description="{loc:Str Key=Settings.Panic.Hint}"
                            Header="{loc:Str Key=Settings.Panic.Header}">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE814;" />
                            </controls:SettingsCard.HeaderIcon>
                            <Button
                                AutomationProperties.AutomationId="PanicWipeButton"
                                AutomationProperties.Name="{loc:Str Key=Settings.Panic.Name}"
                                Command="{x:Bind ViewModel.PanicWipeCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                    <FontIcon
                                        FontSize="{StaticResource IconSizeMedium}"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                        Glyph="&#xE74D;" />
                                    <TextBlock
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                        Text="{loc:Str Key=Settings.Panic.Button}" />
                                </StackPanel>
                            </Button>
                        </controls:SettingsCard>

                        <!--  About (build version + channel)  -->
                        <controls:SettingsCard
                            Header="{loc:Str Key=Settings.About.Header}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE946;}">
                            <TextBlock
                                AutomationProperties.AutomationId="AboutVersionDisplay"
                                IsTextSelectionEnabled="True"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind local:SettingsWindow.AppVersionDisplay}" />
                        </controls:SettingsCard>
                    </StackPanel>
                </ScrollViewer>

                <!--  ===== Privacy pane =====  -->
                <ScrollViewer
                    x:Name="PrivacyPane"
                    Padding="{StaticResource PagePadding}"
                    Visibility="Collapsed">
                    <StackPanel
                        MaxWidth="{StaticResource SettingsContentMaxWidth}"
                        Spacing="{StaticResource SpacingSmall}">
                        <controls:SettingsCard
                            ContentAlignment="Vertical"
                            Header="{loc:Str Key=Settings.Privacy.Status}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE72E;}">
                            <StackPanel Spacing="{StaticResource SpacingMedium}">
                                <Grid ColumnSpacing="{StaticResource SpacingLarge}" RowSpacing="{StaticResource SpacingSmall}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{loc:Str Key=Settings.Privacy.Storage}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="PrivacyStorageDisplay"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind ViewModel.StorageDisplay, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{loc:Str Key=Settings.Privacy.Encryption}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="PrivacyProtectionDisplay"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind ViewModel.ProtectionDisplay, Mode=OneWay}" />
                                </Grid>
                                <TextBlock
                                    AutomationProperties.AutomationId="PrivacyPendingHint"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{loc:Str Key=Settings.Privacy.Pending}"
                                    TextWrapping="Wrap"
                                    Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsStorageRestartPending), Mode=OneWay}" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard
                            ContentAlignment="Vertical"
                            Header="{loc:Str Key=Settings.Privacy.Guarantee}"
                            HeaderIcon="{ui:FontIcon Glyph=&#xE73E;}">
                            <StackPanel Spacing="{StaticResource SpacingSmall}">
                                <!--  Each row is a Grid (Auto icon + * text) so the text wraps to the available width.  -->
                                <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Top"
                                        FontSize="{StaticResource IconSizeMedium}"
                                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                        Glyph="&#xE73E;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Left"
                                        Text="{loc:Str Key=Settings.Privacy.Network}"
                                        TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Top"
                                        FontSize="{StaticResource IconSizeMedium}"
                                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                        Glyph="&#xE73E;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Left"
                                        Text="{loc:Str Key=Settings.Privacy.Telemetry}"
                                        TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Top"
                                        FontSize="{StaticResource IconSizeMedium}"
                                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                        Glyph="&#xE72E;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.AutomationId="PrivacyGuaranteeDisplay"
                                        Text="{x:Bind ViewModel.AtRestGuarantee, Mode=OneWay}"
                                        TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnSpacing="{StaticResource SpacingMedium}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Top"
                                        FontSize="{StaticResource IconSizeMedium}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE946;" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.AutomationId="PrivacyExtraDisplay"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind ViewModel.ExtraProtection, Mode=OneWay}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </controls:SettingsCard>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
