<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ClipVaultApp.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ClipVaultApp"
    xmlns:loc="using:ClipVaultApp.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ClipVaultApp.ViewModels"
    Title="ClipVault"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="ClipVault"
            Grid.Row="0">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="Nav"
            Grid.Row="1"
            AutomationProperties.AutomationId="SettingsNav"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    AutomationProperties.AutomationId="NavSettings"
                    Content="{loc:Str Key=Settings.Nav.Settings}"
                    IsSelected="True"
                    Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.AutomationId="NavPrivacy"
                    Content="{loc:Str Key=Settings.Nav.Privacy}"
                    Tag="privacy">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <!--  ===== 設定ペイン =====  -->
                <ScrollViewer x:Name="SettingsPane" Padding="24">
                    <StackPanel MaxWidth="720" Spacing="20">

                        <!--  言語 / Language  -->
                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{loc:Str Key=Settings.Language.Label}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{loc:Str Key=Settings.Language.Hint}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <ComboBox
                                    Grid.Column="1"
                                    MinWidth="160"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AutomationId="LanguageSelector"
                                    AutomationProperties.Name="{loc:Str Key=Settings.Language.Label}"
                                    DisplayMemberPath="DisplayName"
                                    ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneTime}"
                                    SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <!--  保存方式  -->
                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{loc:Str Key=Settings.Storage.Header}" />
                                <RadioButtons AutomationProperties.AutomationId="StorageModeGroup">
                                    <RadioButton
                                        AutomationProperties.AutomationId="StorageEncryptedRadio"
                                        Content="{loc:Str Key=Settings.Storage.Encrypted}"
                                        IsChecked="{x:Bind ViewModel.IsEncryptedDisk, Mode=TwoWay}" />
                                    <RadioButton
                                        AutomationProperties.AutomationId="StorageVolatileRadio"
                                        Content="{loc:Str Key=Settings.Storage.Volatile}"
                                        IsChecked="{x:Bind ViewModel.IsVolatileMemory, Mode=TwoWay}" />
                                </RadioButtons>
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{loc:Str Key=Settings.Storage.Hint}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!--  鍵の保護（パスフレーズ／Windows Hello のいずれか一方）  -->
                        <Border
                            Style="{StaticResource SettingsSectionStyle}"
                            Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsPassphraseSectionVisible), Mode=OneWay}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{loc:Str Key=Settings.Protection.Header}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{loc:Str Key=Settings.Protection.Current}" />
                                    <TextBlock
                                        AutomationProperties.AutomationId="ProtectionDisplay"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind ViewModel.ProtectionDisplay, Mode=OneWay}" />
                                </StackPanel>
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{loc:Str Key=Settings.Protection.Hint}"
                                    TextWrapping="Wrap" />

                                <!--  共有フィードバック（パスフレーズ／Hello 両操作の結果を表示）  -->
                                <InfoBar
                                    AutomationProperties.AutomationId="PassphraseErrorBar"
                                    IsClosable="False"
                                    IsOpen="{x:Bind ViewModel.HasPassphraseError, Mode=OneWay}"
                                    Message="{x:Bind ViewModel.PassphraseError, Mode=OneWay}"
                                    Severity="Error" />
                                <InfoBar
                                    AutomationProperties.AutomationId="PassphraseSuccessBar"
                                    IsClosable="False"
                                    IsOpen="{x:Bind ViewModel.HasPassphraseSuccess, Mode=OneWay}"
                                    Message="{x:Bind ViewModel.PassphraseSuccess, Mode=OneWay}"
                                    Severity="Success" />

                                <!--  現在のパスフレーズ（パスフレーズ保護中のみ：変更／解除／Hello 切替に使用）  -->
                                <PasswordBox
                                    x:Name="CurrentPassphraseBox"
                                    AutomationProperties.AutomationId="CurrentPassphraseBox"
                                    AutomationProperties.Name="{loc:Str Key=Settings.Passphrase.CurrentHeader}"
                                    Header="{loc:Str Key=Settings.Passphrase.CurrentHeader}"
                                    PasswordChanged="OnCurrentPassphraseChanged"
                                    PlaceholderText="{loc:Str Key=Settings.Passphrase.CurrentPlaceholder}"
                                    Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.HasPassphrase), Mode=OneWay}" />

                                <!--  パスフレーズの設定／変更／解除（DPAPI のみ／パスフレーズのとき。Hello 中は非表示）  -->
                                <StackPanel
                                    Spacing="12"
                                    Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsPassphraseControlsVisible), Mode=OneWay}">
                                    <PasswordBox
                                        x:Name="NewPassphraseBox"
                                        AutomationProperties.AutomationId="NewPassphraseBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Passphrase.NewHeader}"
                                        Header="{loc:Str Key=Settings.Passphrase.NewHeader}"
                                        PasswordChanged="OnNewPassphraseChanged"
                                        PlaceholderText="{loc:Str Key=Settings.Passphrase.NewPlaceholder}" />

                                    <PasswordBox
                                        x:Name="ConfirmPassphraseBox"
                                        AutomationProperties.AutomationId="ConfirmPassphraseBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Passphrase.ConfirmHeader}"
                                        Header="{loc:Str Key=Settings.Passphrase.ConfirmHeader}"
                                        PasswordChanged="OnConfirmPassphraseChanged"
                                        PlaceholderText="{loc:Str Key=Settings.Passphrase.ConfirmPlaceholder}" />

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button
                                            AutomationProperties.AutomationId="SavePassphraseButton"
                                            Command="{x:Bind ViewModel.SavePassphraseCommand}"
                                            Content="{loc:Str Key=Settings.Passphrase.Save}"
                                            IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                            Style="{StaticResource AccentButtonStyle}" />
                                        <Button
                                            AutomationProperties.AutomationId="RemovePassphraseButton"
                                            Command="{x:Bind ViewModel.RemovePassphraseCommand}"
                                            Content="{loc:Str Key=Settings.Passphrase.Remove}"
                                            IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                            Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.HasPassphrase), Mode=OneWay}" />
                                        <ProgressRing
                                            Width="20"
                                            Height="20"
                                            VerticalAlignment="Center"
                                            IsActive="{x:Bind ViewModel.IsPassphraseBusy, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Windows Hello  -->
                                <Border
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                Glyph="&#xE8FB;" />
                                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Windows Hello" />
                                        </StackPanel>
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{loc:Str Key=Settings.Hello.Hint}"
                                            TextWrapping="Wrap" />

                                        <!--  利用不可のヒント（この PC で Hello が使えないとき）  -->
                                        <InfoBar
                                            AutomationProperties.AutomationId="HelloUnavailableBar"
                                            IsClosable="False"
                                            IsOpen="{x:Bind ViewModel.IsHelloUnavailableHintVisible, Mode=OneWay}"
                                            Message="{loc:Str Key=Settings.Hello.Unavailable}"
                                            Severity="Informational" />

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button
                                                AutomationProperties.AutomationId="EnableHelloButton"
                                                Command="{x:Bind ViewModel.EnableHelloCommand}"
                                                Content="{loc:Str Key=Settings.Hello.Enable}"
                                                IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsHelloEnableVisible), Mode=OneWay}" />
                                            <Button
                                                AutomationProperties.AutomationId="DisableHelloButton"
                                                Command="{x:Bind ViewModel.DisableHelloCommand}"
                                                Content="{loc:Str Key=Settings.Hello.Disable}"
                                                IsEnabled="{x:Bind local:SettingsWindow.IsNot(ViewModel.IsPassphraseBusy), Mode=OneWay}"
                                                Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsHelloProtected), Mode=OneWay}" />
                                            <ProgressRing
                                                Width="20"
                                                Height="20"
                                                VerticalAlignment="Center"
                                                IsActive="{x:Bind ViewModel.IsPassphraseBusy, Mode=OneWay}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!--  除外アプリ  -->
                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{loc:Str Key=Settings.Excluded.Header}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{loc:Str Key=Settings.Excluded.Hint}"
                                    TextWrapping="Wrap" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewExcludedAppBox"
                                        Grid.Column="0"
                                        AutomationProperties.AutomationId="NewExcludedAppBox"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Excluded.InputName}"
                                        KeyDown="OnNewExcludedAppKeyDown"
                                        PlaceholderText="{loc:Str Key=Settings.Excluded.Placeholder}"
                                        Text="{x:Bind ViewModel.NewExcludedApp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="AddExcludedAppButton"
                                        AutomationProperties.Name="{loc:Str Key=Settings.Excluded.Add}"
                                        Command="{x:Bind ViewModel.AddExcludedAppCommand}"
                                        Content="{loc:Str Key=Settings.Excluded.Add}" />
                                </Grid>
                                <ItemsControl
                                    AutomationProperties.AutomationId="ExcludedAppsList"
                                    ItemsSource="{x:Bind ViewModel.ExcludedApps, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ExcludedAppViewModel">
                                            <Grid Padding="12,6" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind Name}" />
                                                <Button
                                                    Grid.Column="1"
                                                    AutomationProperties.AutomationId="RemoveExcludedAppButton"
                                                    AutomationProperties.Name="{loc:Str Key=Settings.Excluded.RemoveName}"
                                                    Command="{x:Bind local:SettingsWindow.RemoveExcludedAppCommand}"
                                                    CommandParameter="{x:Bind}"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    ToolTipService.ToolTip="{loc:Str Key=Settings.Excluded.RemoveTooltip}">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!--  汎用パスワードのマスク  -->
                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{loc:Str Key=Settings.Mask.Header}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{loc:Str Key=Settings.Mask.Hint}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AutomationId="MaskPasswordsToggle"
                                    AutomationProperties.Name="{loc:Str Key=Settings.Mask.Header}"
                                    IsOn="{x:Bind ViewModel.MaskGenericPasswords, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <!--  保持  -->
                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{loc:Str Key=Settings.Retention.Header}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{loc:Str Key=Settings.Retention.Hint}"
                                    TextWrapping="Wrap" />
                                <NumberBox
                                    AutomationProperties.AutomationId="MaxAgeDaysBox"
                                    AutomationProperties.Name="{loc:Str Key=Settings.Retention.MaxDays}"
                                    Header="{loc:Str Key=Settings.Retention.MaxDays}"
                                    Maximum="3650"
                                    Minimum="1"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{x:Bind ViewModel.MaxAgeDaysValue, Mode=TwoWay}" />
                                <NumberBox
                                    AutomationProperties.AutomationId="MaxEntriesBox"
                                    AutomationProperties.Name="{loc:Str Key=Settings.Retention.MaxEntries}"
                                    Header="{loc:Str Key=Settings.Retention.MaxEntries}"
                                    Maximum="100000"
                                    Minimum="1"
                                    SmallChange="10"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{x:Bind ViewModel.MaxEntriesValue, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <!--  自動起動  -->
                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{loc:Str Key=Settings.AutoStart.Header}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{loc:Str Key=Settings.AutoStart.Hint}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AutomationId="RunAtStartupToggle"
                                    AutomationProperties.Name="{loc:Str Key=Settings.AutoStart.Header}"
                                    IsOn="{x:Bind ViewModel.RunAtStartup, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <!--  パニックワイプ（破壊的）  -->
                        <Border Style="{StaticResource SettingsDangerSectionStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{loc:Str Key=Settings.Panic.Header}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{loc:Str Key=Settings.Panic.Hint}"
                                    TextWrapping="Wrap" />
                                <Button
                                    AutomationProperties.AutomationId="PanicWipeButton"
                                    AutomationProperties.Name="{loc:Str Key=Settings.Panic.Name}"
                                    Command="{x:Bind ViewModel.PanicWipeCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Glyph="&#xE74D;" />
                                        <TextBlock
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            Text="{loc:Str Key=Settings.Panic.Button}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!--  ===== プライバシーペイン =====  -->
                <ScrollViewer
                    x:Name="PrivacyPane"
                    Padding="24"
                    Visibility="Collapsed">
                    <StackPanel MaxWidth="720" Spacing="20">
                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{loc:Str Key=Settings.Privacy.Status}" />
                                <Grid ColumnSpacing="16" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{loc:Str Key=Settings.Privacy.Storage}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="PrivacyStorageDisplay"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind ViewModel.StorageDisplay, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{loc:Str Key=Settings.Privacy.Encryption}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="PrivacyProtectionDisplay"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind ViewModel.ProtectionDisplay, Mode=OneWay}" />
                                </Grid>
                                <TextBlock
                                    AutomationProperties.AutomationId="PrivacyPendingHint"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{loc:Str Key=Settings.Privacy.Pending}"
                                    TextWrapping="Wrap"
                                    Visibility="{x:Bind local:SettingsWindow.BoolToVisibility(ViewModel.IsStorageRestartPending), Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsSectionStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{loc:Str Key=Settings.Privacy.Guarantee}" />
                                <StackPanel Spacing="8">
                                    <!-- Each row is a Grid (Auto icon + * text) so the text wraps to the available
                                         width and follows the window size instead of overflowing at a fixed width. -->
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            VerticalAlignment="Top"
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                            Glyph="&#xE73E;" />
                                        <TextBlock
                                            Grid.Column="1"
                                            MaxWidth="640"
                                            HorizontalAlignment="Left"
                                            Text="{loc:Str Key=Settings.Privacy.Network}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            VerticalAlignment="Top"
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                            Glyph="&#xE73E;" />
                                        <TextBlock
                                            Grid.Column="1"
                                            MaxWidth="640"
                                            HorizontalAlignment="Left"
                                            Text="{loc:Str Key=Settings.Privacy.Telemetry}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            VerticalAlignment="Top"
                                            FontSize="16"
                                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                            Glyph="&#xE72E;" />
                                        <TextBlock
                                            Grid.Column="1"
                                            MaxWidth="640"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.AutomationId="PrivacyGuaranteeDisplay"
                                            Text="{x:Bind ViewModel.AtRestGuarantee, Mode=OneWay}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            VerticalAlignment="Top"
                                            FontSize="16"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="&#xE946;" />
                                        <TextBlock
                                            Grid.Column="1"
                                            MaxWidth="640"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.AutomationId="PrivacyExtraDisplay"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.ExtraProtection, Mode=OneWay}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
