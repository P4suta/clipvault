<?xml version="1.0" encoding="utf-8" ?>
<!--
    Design tokens. The single source of truth for spacing, sizing, and theme-aware
    brushes so usage sites never hardcode magic numbers. Theme-varying values live in
    ThemeDictionaries (Light / Dark / HighContrast); theme-invariant scales are below.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!-- Kind badge pill. -->
            <StaticResource x:Key="EntryKindBadgeBackgroundBrush" ResourceKey="ControlFillColorSecondaryBrush" />
            <StaticResource x:Key="EntryKindBadgeForegroundBrush" ResourceKey="AccentTextFillColorPrimaryBrush" />
            <!-- History entries rendered as cards via the built-in ListViewItem state brushes. -->
            <StaticResource x:Key="ListViewItemBackground" ResourceKey="CardBackgroundFillColorDefaultBrush" />
            <StaticResource x:Key="ListViewItemBackgroundPointerOver" ResourceKey="ControlFillColorSecondaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundPressed" ResourceKey="ControlFillColorTertiaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <Thickness x:Key="CardBorderThickness">1</Thickness>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <StaticResource x:Key="EntryKindBadgeBackgroundBrush" ResourceKey="ControlFillColorSecondaryBrush" />
            <StaticResource x:Key="EntryKindBadgeForegroundBrush" ResourceKey="AccentTextFillColorPrimaryBrush" />
            <StaticResource x:Key="ListViewItemBackground" ResourceKey="CardBackgroundFillColorDefaultBrush" />
            <StaticResource x:Key="ListViewItemBackgroundPointerOver" ResourceKey="ControlFillColorSecondaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundPressed" ResourceKey="ControlFillColorTertiaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="SubtleFillColorSecondaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="SubtleFillColorTertiaryBrush" />
            <Thickness x:Key="CardBorderThickness">1</Thickness>
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <!-- HC: only system colors, and only those that pair with the default item foregrounds. -->
            <StaticResource x:Key="EntryKindBadgeBackgroundBrush" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="EntryKindBadgeForegroundBrush" ResourceKey="SystemColorButtonTextColorBrush" />
            <StaticResource x:Key="ListViewItemBackground" ResourceKey="SystemColorWindowColorBrush" />
            <StaticResource x:Key="ListViewItemBackgroundPointerOver" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="ListViewItemBackgroundPressed" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelected" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelectedPointerOver" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="ListViewItemBackgroundSelectedPressed" ResourceKey="SystemColorHighlightColorBrush" />
            <Thickness x:Key="CardBorderThickness">2</Thickness>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Spacing scale (4px grid). For Spacing / Row|ColumnSpacing. -->
    <x:Double x:Key="SpacingTiny">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">12</x:Double>
    <x:Double x:Key="SpacingLarge">16</x:Double>
    <x:Double x:Key="SpacingXLarge">24</x:Double>
    <x:Double x:Key="SpacingXXLarge">32</x:Double>

    <!-- Icon / glyph size ramp. -->
    <x:Double x:Key="IconSizeSmall">14</x:Double>
    <x:Double x:Key="IconSizeMedium">16</x:Double>
    <x:Double x:Key="IconSizeLarge">18</x:Double>
    <x:Double x:Key="IconSizeHero">28</x:Double>
    <x:Double x:Key="IconSizeEmptyState">40</x:Double>

    <!-- Control metrics. -->
    <x:Double x:Key="ThumbnailSize">40</x:Double>
    <x:Double x:Key="ProgressRingSize">20</x:Double>
    <x:Double x:Key="ToolbarButtonMinWidth">40</x:Double>
    <x:Double x:Key="InputMinWidth">160</x:Double>
    <x:Double x:Key="DialogButtonMinWidth">120</x:Double>
    <x:Double x:Key="FlyoutMinWidth">220</x:Double>
    <x:Double x:Key="SettingsContentMaxWidth">720</x:Double>
    <x:Double x:Key="FilterIndicatorSize">6</x:Double>

    <!-- Semantic padding / margin. -->
    <Thickness x:Key="PagePadding">24</Thickness>
    <Thickness x:Key="ToolbarPadding">16,12</Thickness>
    <Thickness x:Key="DetailPadding">16,12</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="ListPadding">8,4,8,8</Thickness>
    <Thickness x:Key="ListItemPadding">12,10</Thickness>
    <Thickness x:Key="BadgePadding">6,2</Thickness>
    <Thickness x:Key="ExclusionRowPadding">12,6</Thickness>
    <Thickness x:Key="EntryCardMargin">0,0,0,4</Thickness>
    <Thickness x:Key="SubsectionDividerPadding">0,12,0,0</Thickness>
    <Thickness x:Key="SubsectionDividerThickness">0,1,0,0</Thickness>
    <Thickness x:Key="FilterIndicatorMargin">0,-2,-2,0</Thickness>
</ResourceDictionary>
