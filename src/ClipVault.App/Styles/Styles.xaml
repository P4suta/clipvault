<?xml version="1.0" encoding="utf-8" ?>
<!-- Shared control and item styles. Values come from Tokens.xaml (no inline literals). -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        History entry rendered as a card. The card fill and hover / selection states come from the
        ListViewItem* brushes overridden in Tokens.xaml; here we set the shape, gap, and padding.
    -->
    <Style x:Key="EntryCardItemStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="{StaticResource ListItemPadding}" />
        <Setter Property="Margin" Value="{StaticResource EntryCardMargin}" />
        <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
    </Style>
</ResourceDictionary>
