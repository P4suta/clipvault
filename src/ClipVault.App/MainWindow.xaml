<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ClipVaultApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="using:ClipVaultApp.Localization"
    xmlns:local="using:ClipVaultApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ClipVaultApp.ViewModels"
    Title="ClipVault"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid KeyDown="OnRootKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="ClipVault">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!--  Command bar: search / filter (funnel) / more (gear)  -->
        <Grid
            Grid.Row="1"
            Padding="{StaticResource ToolbarPadding}"
            ColumnSpacing="{StaticResource SpacingSmall}"
            Visibility="{x:Bind local:MainWindow.BoolToVisibilityInverse(ViewModel.IsDetailOpen), Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="0"
                AutomationProperties.AutomationId="SearchBox"
                AutomationProperties.Name="{loc:Str Key=Main.Search.Placeholder}"
                PlaceholderText="{loc:Str Key=Main.Search.Placeholder}"
                QueryIcon="Find"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Filter: kind / app in a single flyout (an accent dot marks an active filter)  -->
            <Button
                x:Name="FilterButton"
                Grid.Column="1"
                MinWidth="{StaticResource ToolbarButtonMinWidth}"
                AutomationProperties.AutomationId="FilterButton"
                AutomationProperties.Name="{loc:Str Key=Main.Filter.Button}"
                ToolTipService.ToolTip="{loc:Str Key=Main.Filter.Button}">
                <Grid>
                    <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE71C;" />
                    <Ellipse
                        Width="{StaticResource FilterIndicatorSize}"
                        Height="{StaticResource FilterIndicatorSize}"
                        Margin="{StaticResource FilterIndicatorMargin}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Fill="{ThemeResource AccentFillColorDefaultBrush}"
                        Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.IsFilterActive), Mode=OneWay}" />
                </Grid>
                <Button.Flyout>
                    <Flyout>
                        <StackPanel MinWidth="{StaticResource FlyoutMinWidth}" Spacing="{StaticResource SpacingSmall}">
                            <TextBlock
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="{loc:Str Key=Main.Filter.KindLabel}" />
                            <ComboBox
                                x:Name="KindFilter"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="KindFilter"
                                AutomationProperties.Name="{loc:Str Key=Main.Filter.Name}"
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.KindFilters}"
                                SelectedItem="{x:Bind ViewModel.SelectedKindFilter, Mode=TwoWay}" />
                            <TextBlock
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="{loc:Str Key=Main.Filter.AppLabel}" />
                            <ComboBox
                                x:Name="AppFilter"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.AutomationId="AppFilter"
                                AutomationProperties.Name="{loc:Str Key=Main.Filter.App.Name}"
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.AppFilters}"
                                SelectedItem="{x:Bind ViewModel.SelectedAppFilter, Mode=TwoWay}" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <!--  More: pause / clear all / settings in a menu  -->
            <Button
                x:Name="OverflowButton"
                Grid.Column="2"
                MinWidth="{StaticResource ToolbarButtonMinWidth}"
                AutomationProperties.AutomationId="OverflowButton"
                AutomationProperties.Name="{loc:Str Key=Main.More.Name}"
                ToolTipService.ToolTip="{loc:Str Key=Main.More.Name}">
                <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE712;" />
                <Button.Flyout>
                    <MenuFlyout>
                        <ToggleMenuFlyoutItem
                            AutomationProperties.AutomationId="PauseMenuItem"
                            IsChecked="{x:Bind ViewModel.IsPaused, Mode=TwoWay}"
                            Text="{loc:Str Key=Main.Pause.Name}" />
                        <MenuFlyoutItem
                            AutomationProperties.AutomationId="ClearAllMenuItem"
                            Command="{x:Bind ViewModel.ClearAllCommand}"
                            Text="{loc:Str Key=Main.ClearAll.Name}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            AutomationProperties.AutomationId="SettingsMenuItem"
                            Click="OnSettingsClick"
                            Text="{loc:Str Key=Main.Settings.Name}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE713;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!--  History list (each entry is a card)  -->
        <Grid Grid.Row="2">
            <ListView
                x:Name="HistoryList"
                Padding="{StaticResource ListPadding}"
                AutomationProperties.AutomationId="HistoryList"
                AutomationProperties.Name="{loc:Str Key=Main.HistoryList.Name}"
                DataFetchSize="2.0"
                IncrementalLoadingThreshold="2.0"
                IncrementalLoadingTrigger="Edge"
                IsItemClickEnabled="True"
                ItemClick="OnItemClick"
                ItemContainerStyle="{StaticResource EntryCardItemStyle}"
                ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                KeyDown="OnHistoryListKeyDown"
                SelectionMode="Single"
                Visibility="{x:Bind local:MainWindow.BoolToVisibilityInverse(ViewModel.IsDetailOpen), Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EntryViewModel">
                        <Grid ColumnSpacing="{StaticResource SpacingMedium}" Loaded="OnEntryRowLoaded">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Thumbnail (image) or glyph (text)  -->
                            <Grid
                                x:Name="EntryThumb"
                                Grid.Column="0"
                                Width="{StaticResource ThumbnailSize}"
                                Height="{StaticResource ThumbnailSize}"
                                VerticalAlignment="Top">
                                <Border
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                    Visibility="{x:Bind local:MainWindow.BoolToVisibility(IsText)}">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource IconSizeLarge}"
                                        Glyph="&#xE8C8;" />
                                </Border>
                                <Image
                                    AutomationProperties.Name="{loc:Str Key=Main.Thumbnail.Name}"
                                    Source="{x:Bind Thumbnail, Mode=OneWay}"
                                    Stretch="UniformToFill"
                                    Visibility="{x:Bind local:MainWindow.BoolToVisibility(IsImage)}" />
                            </Grid>

                            <!--  Preview + kind badge + source / time  -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="{StaticResource SpacingTiny}">
                                <TextBlock
                                    MaxLines="2"
                                    Text="{x:Bind Preview}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap" />
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource SpacingSmall}"
                                    VerticalAlignment="Center">
                                    <Border
                                        Padding="{StaticResource BadgePadding}"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource EntryKindBadgeBackgroundBrush}"
                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                        Visibility="{x:Bind local:MainWindow.BoolToVisibility(HasBadge)}">
                                        <TextBlock
                                            Foreground="{ThemeResource EntryKindBadgeForegroundBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind KindLabel}" />
                                    </Border>
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}">
                                        <Run Text="{x:Bind SourceName}" /><Run Text=" · " /><Run Text="{x:Bind Timestamp}" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!--  View / pin / delete  -->
                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="{StaticResource SpacingTiny}">
                                <Button
                                    AutomationProperties.AutomationId="ViewButton"
                                    AutomationProperties.Name="{loc:Str Key=Main.ViewFull.Name}"
                                    Click="OnViewDetailClick"
                                    Command="{x:Bind local:MainWindow.ViewDetailCommand}"
                                    CommandParameter="{x:Bind}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="{loc:Str Key=Main.ViewFull.Name}">
                                    <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE890;" />
                                </Button>
                                <Button
                                    AutomationProperties.AutomationId="PinButton"
                                    AutomationProperties.Name="{loc:Str Key=Main.TogglePin.Name}"
                                    Command="{x:Bind local:MainWindow.TogglePinCommand}"
                                    CommandParameter="{x:Bind}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="{loc:Str Key=Main.TogglePin.Name}">
                                    <FontIcon
                                        FontSize="{StaticResource IconSizeMedium}"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Glyph="{x:Bind local:MainWindow.PinGlyph(IsPinned)}" />
                                </Button>
                                <Button
                                    AutomationProperties.AutomationId="DeleteButton"
                                    AutomationProperties.Name="{loc:Str Key=Main.Delete.Name}"
                                    Command="{x:Bind local:MainWindow.DeleteCommand}"
                                    CommandParameter="{x:Bind}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="{loc:Str Key=Main.Delete.Tooltip}">
                                    <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE74D;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  Empty state  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="{StaticResource SpacingSmall}"
                Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.IsEmpty), Mode=OneWay}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource IconSizeEmptyState}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Glyph="&#xE8C8;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="{loc:Str Key=Main.Empty.Title}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{loc:Str Key=Main.Empty.Subtitle}" />
            </StackPanel>

            <!--  Full-content view (read-only, inline swap on the same screen)  -->
            <Grid
                Padding="{StaticResource DetailPadding}"
                RowSpacing="{StaticResource SpacingMedium}"
                Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.IsDetailOpen), Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="{StaticResource SpacingSmall}">
                    <Button
                        AutomationProperties.Name="{loc:Str Key=Main.Detail.Back.Name}"
                        Command="{x:Bind ViewModel.CloseDetailCommand}"
                        Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="{loc:Str Key=Main.Detail.Back.Name}">
                        <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE72B;" />
                    </Button>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.DetailTitle, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <TextBox
                    Grid.Row="1"
                    AcceptsReturn="True"
                    AutomationProperties.Name="{loc:Str Key=Main.Detail.FullText.Name}"
                    IsReadOnly="True"
                    IsSpellCheckEnabled="False"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{x:Bind ViewModel.DetailText, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind local:MainWindow.BoolToVisibilityInverse(ViewModel.DetailIsImage), Mode=OneWay}" />

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Auto"
                    Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.DetailIsImage), Mode=OneWay}">
                    <Image
                        x:Name="DetailThumb"
                        AutomationProperties.Name="{loc:Str Key=Main.Detail.Image.Name}"
                        ImageOpened="OnDetailImageOpened"
                        Source="{x:Bind ViewModel.DetailImageSource, Mode=OneWay}"
                        Stretch="Uniform" />
                </ScrollViewer>

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="{StaticResource SpacingSmall}">
                    <Button
                        AutomationProperties.AutomationId="CleanUrlButton"
                        Command="{x:Bind ViewModel.CopyCleanedUrlCommand}"
                        ToolTipService.ToolTip="{loc:Str Key=Main.Detail.CleanUrl}"
                        Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.CanCleanUrl), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE894;" />
                            <TextBlock Text="{loc:Str Key=Main.Detail.CleanUrl}" />
                        </StackPanel>
                    </Button>
                    <Button
                        AutomationProperties.AutomationId="FormatJsonButton"
                        Command="{x:Bind ViewModel.CopyFormattedJsonCommand}"
                        ToolTipService.ToolTip="{loc:Str Key=Main.Detail.FormatJson}"
                        Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.CanFormatJson), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE943;" />
                            <TextBlock Text="{loc:Str Key=Main.Detail.FormatJson}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.CopyDetailCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                            <FontIcon FontSize="{StaticResource IconSizeMedium}" Glyph="&#xE8C8;" />
                            <TextBlock Text="{loc:Str Key=Main.Detail.Copy}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
