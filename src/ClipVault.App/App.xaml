<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ClipVaultApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ClipVaultApp">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- 設定セクションのカード体裁（設定アプリ風のグループ枠）。 -->
            <Style x:Key="SettingsSectionStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource OverlayCornerRadius}" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <!-- 破壊的操作（パニックワイプ）用のカード体裁。 -->
            <Style
                x:Key="SettingsDangerSectionStyle"
                BasedOn="{StaticResource SettingsSectionStyle}"
                TargetType="Border">
                <Setter Property="BorderBrush" Value="{ThemeResource SystemFillColorCriticalBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
