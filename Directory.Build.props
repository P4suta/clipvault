<Project>
  <!-- Build conventions shared by all projects (centralized for cleanliness and consistency). -->
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>true</Deterministic>
    <!-- The entire public API is documented. CS1591 flags missing docs and every public member gets an
         English summary (generated code is auto-exempt via <auto-generated> and explicitly disabled for CS1591 in .editorconfig). -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AccelerateBuildsInVisualStudio>true</AccelerateBuildsInVisualStudio>
  </PropertyGroup>

  <!--
    Collect build outputs under ./artifacts (the .NET 8+ Artifacts Output Layout).
    bin/obj/publish are organized per project x configuration under artifacts/ instead of scattering.
      artifacts/bin/<project>/<config>_<rid>/   ... build output
      artifacts/obj/<project>/                  ... intermediate files
      artifacts/publish/<project>/<config>/     ... published output
  -->
  <PropertyGroup>
    <UseArtifactsOutput>true</UseArtifactsOutput>
  </PropertyGroup>

  <!--
    Strict analyzers: mechanically enforce code quality. Warnings are treated as errors everywhere
    (the staged rollout is complete); `just lint` does a full rebuild (not incremental) so analyzers
    always re-run, and `just check` (format-check + lint + test) is the commit gate.
  -->
  <PropertyGroup Label="Analysis">
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest-all</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    <!-- Warnings are errors everywhere (the strict rollout is complete). -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <!--
    Restore integrity: generate a committed packages.lock.json per project so the full
    (transitive) dependency graph is pinned with content hashes. CI/Release restore in locked
    mode (see the `restore-locked` recipe) to fail closed if the lock ever drifts.
  -->
  <PropertyGroup Label="Restore integrity">
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
  </PropertyGroup>

  <!--
    Source Link / reproducible build. Source Link ships in the .NET SDK (8+) and is enabled by
    default, so no PackageReference is needed; these properties embed the commit + repo URL and any
    untracked/generated sources, and use a portable PDB. Repo URL embedding activates once an
    `origin` remote exists. Deterministic=true (above) + CI-gated ContinuousIntegrationBuild make
    builds verifiable; provenance attestation is the practical build-integrity guarantee (R2R in
    Release trades bit-for-bit reproducibility for startup speed). Keep PublishTrimmed=false (WinUI
    resolves XAML types via reflection).
  -->
  <PropertyGroup Label="Source Link / reproducibility">
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>portable</DebugType>
  </PropertyGroup>

  <!-- Analyzers shared by all projects (build-time only; not included in outputs). -->
  <ItemGroup Label="Analyzers">
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive" />
    <PackageReference Include="Meziantou.Analyzer" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive" />
    <PackageReference Include="SonarAnalyzer.CSharp" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive" />
    <PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive" />
  </ItemGroup>

  <!-- Supply StyleCop settings to all projects (shared root stylecop.json). -->
  <ItemGroup>
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)stylecop.json" Link="stylecop.json" />
  </ItemGroup>
</Project>
