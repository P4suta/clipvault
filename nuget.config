<?xml version="1.0" encoding="utf-8"?>
<!--
  Restrict package restore to a single trusted source and map every package to it.
  packageSourceMapping pins the *origin* of each package (defense against dependency-confusion),
  which is orthogonal to and complements Central Package Management (which pins versions).
-->
<configuration>
  <packageSources>
    <!-- clear inherited/machine-level sources so only the sources below are ever used -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <!-- NuGetAudit (on by default in .NET 10) sources advisory data from here. -->
  <auditSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </auditSources>
</configuration>
